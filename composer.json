{
    "name": "liqaa/liqaa",
    "description": "Server-side PHP client for the LIQAA Public API. Drop-in video calls + messaging.",
    "keywords": ["liqaa", "video", "webrtc", "video-api", "messaging", "rtc", "tkawen", "real-time", "video-sdk"],
    "homepage": "https://liqaa.io",
    "license": "MIT",
    "authors": [
        {
            "name": "Yaakoub HARTEM",
            "email": "yaakoub.hartem.mhsi@gmail.com",
            "homepage": "https://liqaa.io"
        }
    ],
    "support": {
        "issues": "https://github.com/hartemyaakoub/liqaa-php/issues",
        "source": "https://github.com/hartemyaakoub/liqaa-php",
        "docs": "https://liqaa.io/docs",
        "email": "partners@tkawen.com"
    },
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-hash": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^2.1",
        "laravel/pint": "^1.13"
    },
    "autoload": {
        "psr-4": {
            "Liqaa\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Liqaa\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse src --level=8",
        "fmt":  "pint"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
